{
   "$schema": "https://json.schemastore.org/tsconfig",
   "compilerOptions": {
      "jsx": "react-jsx",
      "jsxImportSource": "ags/gtk4",
         "lib": ["ES2023", "DOM"],
      "module": "ES2022",
      "moduleResolution": "Bundler",
      "paths": {
         "@/*": ["./*"]
      },
      "strict": false,
      "target": "ES2020",
      "experimentalDecorators": false
   }
}

